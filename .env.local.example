# Copy to `.env.local` and fill in. Required for the site to load real content.
# These are also the env vars to set in the Vercel project settings.

# From your Sanity project (sanity.io/manage). Safe to expose to the browser.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

# Sanity API version (a date). Leave as-is unless you know you need a newer one.
NEXT_PUBLIC_SANITY_API_VERSION=2025-06-01

# Read token with "Viewer" rights — used for draft previews + the Live Content API.
# Create at: sanity.io/manage -> project -> API -> Tokens. Keep this server-only (no NEXT_PUBLIC_).
SANITY_API_READ_TOKEN=

# The deployed site origin, used by the Studio's Presentation (visual editing) tool.
# Local dev can leave this unset (defaults to http://localhost:3000).
# In production set to e.g. https://reececox.com
NEXT_PUBLIC_SITE_URL=
